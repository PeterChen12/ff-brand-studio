# ── Model Providers (copy from CreatoRain .env) ─────────────────────────────
ANTHROPIC_API_KEY=           # Claude Sonnet (copy/ZH) + Claude Opus (Brand Guardian)
OPENAI_API_KEY=              # GPT Image 2 (requires org verification at platform.openai.com)
FAL_KEY=                     # Flux Pro (photoreal hero shots) + Kling 2.6 (video)

# ── Cloudflare (existing account, new scoped token) ──────────────────────────
CLOUDFLARE_ACCOUNT_ID=       # same as CreatoRain — from existing .env
CLOUDFLARE_API_TOKEN=        # NEW scoped token: Workers Scripts:Edit + R2:Edit + KV:Edit

# ── Cloudflare R2 (create bucket ff-brand-studio-assets) ─────────────────────
R2_ACCESS_KEY_ID=            # from R2 API token creation
R2_SECRET_ACCESS_KEY=        # from R2 API token creation
R2_BUCKET=ff-brand-studio-assets
R2_PUBLIC_URL=               # e.g. https://pub-XXXXX.r2.dev

# ── Postgres (same server as CreatoRain, new database ff_brand_studio) ───────
PGHOST=170.9.252.93
PGPORT=5433
PGDATABASE=ff_brand_studio
PGUSER=postgres
PGPASSWORD=                  # same as CreatoRain PGPASSWORD

# ── Langfuse (cloud.langfuse.com free tier) ───────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
