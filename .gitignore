node_modules/
dist/
.next/
out/
build/
.env
.env.*
!.env.example
.dev.vars
*.log
.turbo/
.wrangler/
.DS_Store
Thumbs.db
# secrets — defense in depth
scripts/secrets.json
**/secrets.json

# Hard-queue inbox — queued tasks not tracked
inbox/*.md
inbox/processed/*.md
!inbox/.gitkeep
!inbox/processed/.gitkeep

# Phase G — local Clerk creds
apps/dashboard/.env.local

# Per-user Claude Code permission overrides (do not commit)
.claude/settings.local.json

# Vitest coverage reports (regenerated locally)
coverage/
**/coverage/

# TS incremental-build manifests — when checked in with composite: true,
# tsc reads them on CI checkout, decides "build is up to date", and emits
# NOTHING, leaving consumers unable to resolve dist/*.js (see CI run
# 25905098106 — phase-h/phase-g undeploy incident 2026-05-15).
*.tsbuildinfo
**/tsconfig.tsbuildinfo
